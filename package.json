{
  "name": "kitr",
  "version": "1.0.0",
  "description": "lightweight dependency injection for TypeScript and Lit",
  "author": "colourlabs",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    },
    "./lit": {
      "import": "./dist/esm/lit.js",
      "require": "./dist/cjs/lit.js",
      "types": "./dist/esm/lit.d.ts"
    },
    "./controller": {
      "import": "./dist/esm/controller.js",
      "require": "./dist/cjs/controller.js",
      "types": "./dist/esm/controller.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "dev": "tsc -w",
    "test": "vitest",
    "test:wtr": "web-test-runner"
  },
  "keywords": ["dependency-injection", "lit", "web-components", "typescript"],
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "happy-dom": "^20.9.0",
    "lit": "^3.0.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
